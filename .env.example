# Copy to .env.local for local Vercel dev (vercel dev command)

# Admin secret — choose any strong password; set the same value in
# Vercel project settings → Environment Variables
ADMIN_SECRET=change-me

# Vercel Blob token — created automatically when you connect a Blob store.
# In Vercel dashboard: Storage → Create Database → Blob → connect to this project.
# The token is then added to env vars automatically.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
